# -----------------------------------------------------------------------------
# WoW Analytics — exemplo de variáveis de ambiente.
# Copie para .env (nunca commitar) e preencha com credenciais reais.
# -----------------------------------------------------------------------------

# === Blizzard Battle.net OAuth ===
# Cadastre um app em https://develop.battle.net/access/clients
BLIZZARD_CLIENT_ID=
BLIZZARD_CLIENT_SECRET=
# Regiões ativas (csv). us,eu,kr,tw
BLIZZARD_REGIONS=us,eu

# === Raider.IO (sem auth, mas centraliza base URL e UA) ===
RAIDERIO_BASE_URL=https://raider.io/api/v1
RAIDERIO_USER_AGENT=wow-analytics/0.1 (+https://github.com/italochagas/wow-analytics)

# === Supabase Postgres ===
# Connection direta (porta 5432) — usar no ingestor (migrations, jobs).
DATABASE_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
# Connection via pooler (transaction mode, 6543) — usar na API serverless.
DATABASE_URL_POOLED=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Cloudflare R2 (S3-compat) ===
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=wow-analytics-raw
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# === Sentry ===
SENTRY_DSN_API=
SENTRY_DSN_WEB=
SENTRY_ENVIRONMENT=development

# === Ingestion tunables ===
INGEST_CONCURRENCY=8
INGEST_SNAPSHOT_LIMIT=500
INGEST_RUN_ID=                 # opcional; se vazio, gera uuid por run
LOG_LEVEL=INFO
LOG_FORMAT=json                # json | console

# === API (FastAPI) ===
API_ALLOWED_ORIGINS=http://localhost:3000

# === Web (Nuxt) — usadas em runtimeConfig ===
NUXT_PUBLIC_API_BASE=http://localhost:8000
NUXT_PUBLIC_SENTRY_DSN=
